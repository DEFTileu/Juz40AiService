# LLM Provider
LLM_PROVIDER=gemini

# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API (альтернатива)
OPENAI_API_KEY=your_openai_api_key_here

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=juz40_codebase

# Пути к коду для индексации
BACKEND_CODE_PATH=/path/to/juz40/backend/src
FRONTEND_CODE_PATH=/path/to/juz40/frontend/src

# Параметры агента
CHUNK_SIZE=800
CHUNK_OVERLAP=100
TOP_K_RESULTS=5
LLM_TEMPERATURE=0
